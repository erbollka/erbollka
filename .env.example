# Скопируй этот файл в .env.local и вставь свои ключи из Supabase.
# Где взять: supabase.com → твой проект → Project Settings → API
# ⚠️  .env.local НИКОГДА не коммить в git (он уже в .gitignore).

VITE_SUPABASE_URL=https://ТВОЙ-ПРОЕКТ.supabase.co
VITE_SUPABASE_ANON_KEY=твой-anon-public-ключ

# Серверный ключ Gemini для Supabase Edge Function.
# Не используй его во фронтенде как VITE_*.
GEMINI_API_KEY=твой-gemini-api-key
